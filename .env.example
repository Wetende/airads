# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here

# Environment Mode (True=development, False=production)
DEBUG=True

# Allowed Hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Engine: sqlite3, mysql, or postgresql
DB_ENGINE=sqlite3

# Database (for mysql/postgresql only)
DB_NAME=crossview
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# CSRF Trusted Origins (comma-separated)
CSRF_TRUSTED_ORIGINS=http://localhost:8001,http://127.0.0.1:8001

# Production Security (set to False for local testing without HTTPS)
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False

# Paystack Payments
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=
# Optional legacy redirect callback while Popup is active.
PAYSTACK_CALLBACK_URL=http://localhost:8000/payments/paystack/callback/

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=DEBUG

# Performance tuning
DB_CONN_MAX_AGE=60
CACHE_LOCATION=/tmp/crossview-cache
CACHE_TIMEOUT=900
ENABLE_PERF_LOGGING=False
SLOW_REQUEST_MS=400
