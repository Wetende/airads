# Django Settings
DJANGO_SECRET_KEY=generate-with-python3 -c "import secrets; print(secrets.token_urlsafe(50))"

# Environment Mode
DEBUG=False

# Allowed Hosts (main site + virtual campus subdomain)
ALLOWED_HOSTS=airads.ac.ke,www.airads.ac.ke,virtual.airads.ac.ke
VIRTUAL_CAMPUS_HOSTS=virtual.airads.ac.ke

# Database — use PostgreSQL in production
DB_ENGINE=postgresql
DB_NAME=airads_db
DB_USER=airads_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# CORS Origins — main site + virtual campus subdomain
CORS_ORIGINS=https://airads.ac.ke,https://www.airads.ac.ke,https://virtual.airads.ac.ke

# CSRF Trusted Origins
CSRF_TRUSTED_ORIGINS=https://airads.ac.ke,https://www.airads.ac.ke,https://virtual.airads.ac.ke

# Production Security (HTTPS enabled)
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True

# Logging Level
LOG_LEVEL=WARNING
