# Django Settings
DJANGO_SECRET_KEY=generate-with-python3 -c "import secrets; print(secrets.token_urlsafe(50))"

# Environment Mode
DEBUG=False

# Allowed Hosts (main site + virtual campus subdomain)
ALLOWED_HOSTS=airads.ac.ke,www.airads.ac.ke,virtual.airads.ac.ke
VIRTUAL_CAMPUS_HOSTS=virtual.airads.ac.ke

# Virtual Campus URL — used for the "Virtual Campus" button in nav/footer
# Production: https://virtual.airads.ac.ke
# Local dev:  http://localhost:8000
VIRTUAL_CAMPUS_BASE_URL=https://virtual.airads.ac.ke

# Database — use PostgreSQL in production
DB_ENGINE=postgresql
DB_NAME=airads_db
DB_USER=airads_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# CORS Origins — main site + virtual campus subdomain
CORS_ORIGINS=https://airads.ac.ke,https://www.airads.ac.ke,https://virtual.airads.ac.ke

# CSRF Trusted Origins
CSRF_TRUSTED_ORIGINS=https://airads.ac.ke,https://www.airads.ac.ke,https://virtual.airads.ac.ke

# Production Security (HTTPS enabled)
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin

# Uploaded media files
MEDIA_URL=/media/
MEDIA_ROOT=/home1/airadsac/lms/media
# Preferred: keep this False and serve /media/ with Apache/LiteSpeed.
# Set True only when cPanel cannot map /media/ directly to MEDIA_ROOT.
SERVE_MEDIA_FILES=True

# Optional inquiry recipient override. Leave blank to use PlatformSettings.
INQUIRY_NOTIFICATION_EMAIL=

# Optional Google Classroom companion integration. Keep One Tap sign-in separate.
GOOGLE_CLASSROOM_ENABLED=False
GOOGLE_CLASSROOM_CLIENT_ID=
GOOGLE_CLASSROOM_CLIENT_SECRET=
GOOGLE_CLASSROOM_REDIRECT_URI=
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GOOGLE_CLASSROOM_TOKEN_ENCRYPTION_KEY=
PLATFORM_PUBLIC_BASE_URL=

# Logging Level
LOG_LEVEL=WARNING
